# === Echo Agent 配置 ===

# 模型提供商: anthropic / openai / deepseek
ECHO_PROVIDER=deepseek

# ── DeepSeek（推荐，通过 Anthropic 兼容 API）─────
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
DEEPSEEK_API_BASE=

# ── Anthropic 原生 ───────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── OpenAI（备选）────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ── Ollama（本地）────────────────────────────────
# OLLAMA_MODEL=qwen3:4b
# OLLAMA_HOST=http://localhost:11434

# ── 通用配置 ─────────────────────────────────────
ECHO_MAX_STEPS=25
ECHO_APPROVAL=ask
